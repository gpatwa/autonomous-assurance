# KavachIQ Platform — Local Development Environment
# Copy to .env.local and fill in values.

# ─── Azurite (local Azure Storage emulator) ───────────────────────────────
AZURITE_BLOB_URL=http://127.0.0.1:10000/devstoreaccount1
AZURITE_TABLE_URL=http://127.0.0.1:10002/devstoreaccount1
AZURITE_QUEUE_URL=http://127.0.0.1:10001/devstoreaccount1
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1

# ─── Test tenant (real Entra tenant for Graph API calls) ──────────────────
# These must be filled in after WI-01/WI-02/WI-03 from Phase 0 board.
#
# Certificate auth is the target (ENGINEERING_BOOTSTRAP_DECISIONS §5).
# Client-secret fallback is accepted for the very first Phase 0 spikes only
# and must be replaced with cert auth before Phase 1.
SP_READ_TENANT_ID=
SP_READ_CLIENT_ID=
SP_READ_CERTIFICATE_PATH=
SP_READ_CLIENT_SECRET=

SP_EXECUTE_TENANT_ID=
SP_EXECUTE_CLIENT_ID=
SP_EXECUTE_CERTIFICATE_PATH=
SP_EXECUTE_CLIENT_SECRET=

# ─── SP-Setup (tenant-population writes for WI-01 automation) ─────────────
# Separate principal from SP-Read and SP-Execute. Required only when running
# `setup-test-tenant --mode setup --apply`. Permissions needed:
#   User.ReadWrite.All, Group.ReadWrite.All, Application.ReadWrite.All,
#   GroupMember.ReadWrite.All
# Do NOT reuse SP-Execute here; SP-Execute has only GroupMember.ReadWrite.All.
SP_SETUP_TENANT_ID=
SP_SETUP_CLIENT_ID=
SP_SETUP_CERTIFICATE_PATH=
SP_SETUP_CLIENT_SECRET=

# ─── Tenant domain + initial password for created users ───────────────────
# Required for `setup-test-tenant --mode setup --apply`.
# TENANT_DOMAIN is the verified domain used for UPNs (e.g. contoso.onmicrosoft.com).
# TENANT_SETUP_INITIAL_PASSWORD is applied to created users with
# forceChangePasswordNextSignIn=true. Must be at least 12 characters.
TENANT_DOMAIN=
TENANT_SETUP_INITIAL_PASSWORD=

# ─── Cosmos DB (use Azure instance or local emulator if available) ────────
# COSMOS_ENDPOINT=https://localhost:8081
