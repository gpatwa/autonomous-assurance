# ─── KavachIQ Autonomous Assurance — Staging Environment ──────────────────
# Copy this file to .env.local and fill in values.

# ─── Resend (demo request emails) ────────────────────────────────────────
# Required for staging. Form submissions send email via Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEMO_REQUEST_TO_EMAIL=team@kavachiq.com

# ─── PostHog (analytics) ─────────────────────────────────────────────────
# Required for staging. Tracks CTA clicks and form events.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
