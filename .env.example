# ─── KavachIQ Autonomous Assurance ─────────────────────────────────────────
# Copy this file to .env.local and fill in values as needed.

# ─── Demo request webhook (optional) ──────────────────────────────────────
# When set, form submissions POST to this URL as JSON.
# When unset, submissions are stored locally in .data/demo-requests.json.
# Can be a CRM webhook, Azure Logic App, email relay, etc.
# DEMO_REQUEST_WEBHOOK_URL=https://your-webhook-url.com/api/demo

# ─── Analytics (optional, future) ────────────────────────────────────────
# NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kavachiq.com
