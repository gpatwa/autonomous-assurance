# ─── KavachIQ Autonomous Assurance ────────────────────────────────────────
# Copy this file to .env.local and fill in values.

# ─── Site origin / SEO ────────────────────────────────────────────────────
# Single source of truth for the public hostname. Drives metadataBase,
# canonical tags, sitemap URLs, robots rules, and JSON-LD identity.
#
#   https://agents.kavachiq.com   → public product, indexable
#   https://staging.kavachiq.com  → non-public test env, noindex (override)
#   http://localhost:3000         → dev, noindex
#
# Unset = defaults to the public production origin (agents.kavachiq.com).
# See docs/AGENTS_SUBDOMAIN_SEO_PLAN.md.
NEXT_PUBLIC_SITE_ORIGIN=https://agents.kavachiq.com

# ─── Resend (demo request emails) ────────────────────────────────────────
# Required for staging/prod. Form submissions send email via Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEMO_REQUEST_TO_EMAIL=team@kavachiq.com

# ─── PostHog (analytics) ─────────────────────────────────────────────────
# Required. Tracks CTA clicks and form events.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
